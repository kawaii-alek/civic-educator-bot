# Civic Educator Bot - Backend Environment Variables

# Project Name
PROJECT_NAME="Civic Educator Bot"

# Environment (set to 'production' in production to enforce secure keys)
ENV="development"

# Secret local API key for client-server authentication
# In production, change this to a secure random string (e.g., generate using: `openssl rand -hex 32` or `python -c "import secrets; print(secrets.token_hex(32))"`)
API_KEY_LOCAL="my_secret_key123"

# Google Gemini API Key
# Required for Swahili query/response translation. If empty, the bot operates in offline fallback mode.
GEMINI_API_KEY=""

# Allowed CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3008"

# Ollama settings
OLLAMA_HOST="http://localhost:11434"
OLLAMA_TIMEOUT=5.0
OLLAMA_RETRIES=2

# Rate limiting
RATE_LIMIT_LIMIT=60
RATE_LIMIT_WINDOW=60

# Model settings
CUSTOM_MODEL="civic-bot:latest"
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"
